generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(uuid())
  username       String    @unique
  email          String    @unique
  password_hash  String
  full_name      String
  university     String?
  field_of_study String?
  skill_level    String?
  profile_image  String?
  bio            String?
  links          String? // JSON string for social links (github, linkedin, website)
  country        String? // User's country
  dob            String? // Date of Birth
  role           String    @default("user")
  is_verified    Boolean   @default(false)
  verify_token   String?
  reset_token    String?
  reset_expires  DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  projects          Project[]        @relation("ProjectOwner")
  project_members   ProjectMember[]
  messages_sent     Message[]        @relation("MessageSender")
  messages_received Message[]        @relation("MessageReceiver")
  project_messages  ProjectMessage[]
  applications      Application[]
  notifications     Notification[]

  @@map("users")
}

model Project {
  id           String    @id @default(uuid())
  title        String
  description  String
  field        String
  owner_id     String
  team_size    Int
  deadline     DateTime?
  visibility   String    @default("public")
  banner_image String? // URL or base64 for project banner
  views        Int       @default(0)
  stars        Int       @default(0)
  created_at   DateTime  @default(now())

  owner            User             @relation("ProjectOwner", fields: [owner_id], references: [id])
  members          ProjectMember[]
  project_messages ProjectMessage[]
  roles            ProjectRole[]
  applications     Application[]

  @@index([owner_id])
  @@map("projects")
}

model ProjectMember {
  id         String   @id @default(uuid())
  project_id String
  user_id    String
  role       String   @default("member")
  joined_at  DateTime @default(now())

  project Project @relation(fields: [project_id], references: [id])
  user    User    @relation(fields: [user_id], references: [id])

  @@index([project_id])
  @@index([user_id])
  @@map("project_members")
}

model ProjectRole {
  id          String   @id @default(uuid())
  project_id  String
  title       String // e.g., "Frontend Developer", "UI Designer"
  description String?
  questions   String? // JSON array of screening questions
  is_filled   Boolean  @default(false)
  created_at  DateTime @default(now())

  project      Project       @relation(fields: [project_id], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([project_id])
  @@map("project_roles")
}

model Application {
  id         String   @id @default(uuid())
  project_id String
  role_id    String
  user_id    String
  answers    String? // JSON array of answers matching the role's questions
  status     String   @default("pending") // pending, accepted, rejected
  created_at DateTime @default(now())

  project Project     @relation(fields: [project_id], references: [id], onDelete: Cascade)
  role    ProjectRole @relation(fields: [role_id], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [user_id], references: [id])

  @@unique([role_id, user_id])
  @@index([project_id])
  @@map("applications")
}

model Message {
  id           String   @id @default(uuid())
  sender_id    String
  receiver_id  String
  message_text String?
  file_url     String?
  created_at   DateTime @default(now())

  sender   User @relation("MessageSender", fields: [sender_id], references: [id])
  receiver User @relation("MessageReceiver", fields: [receiver_id], references: [id])

  @@index([sender_id])
  @@index([receiver_id])
  @@map("messages")
}

model ProjectMessage {
  id           String   @id @default(uuid())
  project_id   String
  sender_id    String
  message_text String
  created_at   DateTime @default(now())

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  sender  User    @relation(fields: [sender_id], references: [id])

  @@index([project_id])
  @@index([sender_id])
  @@map("project_messages")
}

model Notification {
  id         String   @id @default(uuid())
  user_id    String
  type       String // "application", "accepted", "rejected", "message"
  title      String
  body       String
  link       String? // Optional navigation path
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@map("notifications")
}
